    {
      "name": "POST - Crear cliente (201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code es 201', () => pm.response.to.have.status(201));",
              "pm.test('Devuelve el cliente creado', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.email).to.eql('ana.lopez@ejemplo.cl');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Ana Lopez\",\n  \"email\": \"ana.lopez@ejemplo.cl\",\n  \"telefono\": \"+56911223344\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/clientes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "clientes"]
        },
        "description": "Crea un nuevo cliente. Devuelve 201 con el registro creado."
      }
    },
    {
      "name": "POST - Email duplicado (409)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code es 409', () => pm.response.to.have.status(409));",
