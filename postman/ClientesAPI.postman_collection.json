  "item": [
    {
      "name": "GET - Listar todos los clientes (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code es 200', () => pm.response.to.have.status(200));",
              "pm.test('Respuesta tiene success=true', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/clientes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "clientes"]
        },
        "description": "Devuelve la lista completa de clientes registrados."
      }
    },
    {
      "name": "GET - Obtener cliente por ID (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code es 200', () => pm.response.to.have.status(200));",
              "pm.test('Cliente tiene los campos correctos', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data).to.have.property('id_cliente');",
              "  pm.expect(json.data).to.have.property('nombre');",
              "  pm.expect(json.data).to.have.property('email');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/clientes/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "clientes", "1"]
        },
        "description": "Obtiene el cliente con id_cliente = 1."
      }
    },
