# =====================================================================
# Variables de entorno - PLANTILLA
# =====================================================================
# Copia este archivo como .env y completa los valores reales.
# El archivo .env NO se sube al repositorio (esta en .gitignore).
# =====================================================================

# Entorno: development | production
NODE_ENV=development

# Servidor
PORT=3000

# Base de datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=cib302_clientes
DB_PORT=3306

# CORS: dominio(s) permitidos. Usa * para permitir cualquier origen (solo en dev).
CORS_ORIGIN=*
